# 주식 AI 채팅용 OpenAI API 키
# 이 파일을 secrets.toml 로 복사한 뒤 실제 키를 입력하세요.
# 또는 환경변수 OPENAI_API_KEY 로 설정해도 됩니다.

OPENAI_API_KEY = "sk-여기에_OpenAI_API_키_입력"

